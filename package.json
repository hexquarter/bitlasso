{
  "name": "bitlasso-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/ui",
    "build": "npm run build --workspace=packages/sdk && npm run build --workspace=packages/ui",
    "build:sdk": "npm run build --workspace=packages/sdk",
    "build:ui": "npm run build --workspace=packages/ui",
    "lint": "npm run lint --workspace=packages/ui",
    "preview": "npm run preview --workspace=packages/ui",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1"
  }
}
